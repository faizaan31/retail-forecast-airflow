# Example variables for a cloud-style deployment (Composer / MWAA / self-hosted + managed Postgres).
# Copy values into your real secret store or CI deploy job — do not commit secrets.

# Optional: pull pre-built images instead of local `build:` (set in compose override in your fork)
# IMAGE_REGISTRY=ghcr.io/your-org/
# IMAGE_TAG=3.1.0
# API_IMAGE_TAG=latest
# DASH_IMAGE_TAG=latest

# Managed metadata DB (replace host/user/password)
# AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:***@db.example.com:5432/airflow

# Required for multi-node / shared deploys (generate new values)
# AIRFLOW__CORE__FERNET_KEY=
# AIRFLOW__CORE__EXECUTION_API_JWT_SECRET_KEY=
